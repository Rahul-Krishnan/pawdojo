# Supabase - get these from your Supabase project dashboard (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Trusted public base URL for OAuth redirect bounces (no trailing slash).
# Pins the post-login redirect to this origin so a spoofed Host header
# cannot turn the auth callback into an open redirect. Set this in prod.
NEXT_PUBLIC_SITE_URL=https://pawdojo.app

# E2E test account credentials (used by Playwright specs)
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=your-test-password
